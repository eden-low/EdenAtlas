# EdenAtlas — environment variable names for future Netlify Functions.
#
# This file documents NAMES ONLY. It contains no working values and is safe to commit.
# Do NOT put real secrets here, in netlify.toml, in any frontend .js file, or in any
# Firestore document — they are all readable by anyone who loads the site.
#
# Real values belong in: Netlify → Site/Project configuration → Environment variables
# (per Netlify deploy context, e.g. "Production" vs "Deploy previews" if the values differ).
# Netlify Functions read them server-side via process.env — they are never bundled into
# anything the browser downloads.
#
# Nothing in this file is wired up yet. The only function that exists today
# (netlify/functions/health.js) reads none of these. They are placeholders for the future
# AI-assistant architecture described in docs/ai-architecture.md.

# --- Future server-side AI function (not implemented yet) ---
AI_PROVIDER=replace_me
AI_PROVIDER_API_KEY=replace_me
AI_MODEL=replace_me

# --- Firebase Admin SDK (server-side only; bypasses Firestore/Storage Security Rules,
#     so it must never be used from the browser and never committed as a file) ---
FIREBASE_PROJECT_ID=replace_me
# Paste the *contents* of a service-account JSON key as a single-line value via the Netlify
# UI (not a file path) — never commit the service-account JSON file itself.
FIREBASE_SERVICE_ACCOUNT=replace_me

# --- CORS / origin allowlist for Netlify Functions ---
ALLOWED_ORIGIN=https://edenatlas.netlify.app
